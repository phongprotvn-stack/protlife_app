rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─────────────────────────────────────────────────
    // User collections — all writes MUST go through backend API
    // Only Admin UID can write directly (for emergencies)
    // ─────────────────────────────────────────────────
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() && request.auth.uid == 'UID_CUA_PROT';
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // User data: read = owner or admin, write = admin ONLY (API writes with admin SDK)
    match /users/{userId}/{document=**} {
      allow read: if isOwner(userId) || isAdmin();
      allow write: if isAdmin();  // Backend API uses Admin SDK — bypasses rules
      // NOTE: Firebase Admin SDK bypasses Security Rules entirely.
      // This rule only affects direct client SDK writes (which should be blocked).
      // All mutations go through the backend API.
    }

    // ─────────────────────────────────────────────────
    // Public collections — readable by anyone
    // ─────────────────────────────────────────────────
    match /public/{document=**} {
      allow read: if true;
      allow create: if isAdmin();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // ─────────────────────────────────────────────────
    // Deny everything else
    // ─────────────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
